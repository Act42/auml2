PP_MIN_LOG_LEVEL\"] = \"3\"\n\nDATA_DIR = Path(\"/kaggle/input/competitions/birdclef-2026\")\nSAMPLE_RATE = 32000\nAUDIO_LEN = 60 * SAMPLE_RATE\nCHUNK_LEN = 5 * SAMPLE_RATE\n\nsub_df = pd.read_csv(DATA_DIR / 'sample_submission.csv')\nBIRD_SPECIES = sub_df.columns[1:].tolist()\nNUM_BIRDS = len(BIRD_SPECIES)\n\ndf_labels = pd.read_csv(DATA_DIR / \"train_soundscapes_labels.csv\").dropna(subset=['primary_label'])\n\nunique_files = df_labels['filename'].unique()\nnp.random.seed(42)\nnp.random.shuffle(unique_files)\nsplit_idx = int(len(unique_files) * 0.8)\n\ntrain_files = set(unique_files[:split_idx])\nval_files = set(unique_files[split_idx:])\n\nprint(f\"Файлів для навчання: {len(train_files)}, для валідації: {len(val_files)}\")","metadata":{"execution":{"iopub.status.busy":"2026-04-06T20:40:39.140447Z","iopub.execute_input":"2026-04-06T20:40:39.141192Z","iopub.status.idle":"2026-04-06T20:40:39.160400Z","shell.execute_reply.started":"2026-04-06T20:40:39.141163Z","shell.execute_reply":"2026-04-06T20:40:39.159688Z"},"papermill":{"duration":5.092183,"end_time":"2026-04-06T19:30:17.010720+00:00","exception":false,"start_time":"2026-04-06T19:30:11.918537+00:00","status":"completed"},"tags":[],"trusted":true},"outputs":[{"name":"stdout","text":"Файлів для навчання: 52, для валідації: 14\n","output_type":"stream"}],"execution_count":29},{"id":"415a7993","cell_type":"code","source":"def get_audio_features(chunk):\n    mel = librosa.feature.melspectrogram(y=chunk, sr=SAMPLE_RATE, n_mels=128, n_fft=2048, hop_length=512)\n    mel_db = librosa.power_to_db(mel, ref=np.max)\n    mfcc = librosa.feature.mfcc(y=chunk, sr=SAMPLE_RATE, n_mfcc=40, n_fft=2048, hop_length=512)\n    \n    cent = librosa.feature.spectral_centroid(y=chunk, sr=SAMPLE_RATE, hop_length=512)\n    bw = librosa.feature.spectral_bandwidth(y=chunk, sr=SAMPLE_RATE, hop_length=512)\n    roll = librosa.feature.spectral_rolloff(y=chunk, sr=SAMPLE_RATE, hop_length=512)\n    zcr = librosa.feature.zero_crossing_rate(y=chunk, hop_length=512)\n    \n    combined = np.vstack([mel_db, mfcc, cent, bw, roll, zcr])\n    \n    if combined.shape[1] < 313:\n        combined = np.pad(combined, ((0, 0), (0, 313 - combined.shape[1])))\n    else:\n        combined = combined[:, :313]\n        \n    return combined.flatten()\n\ndef build_xy(filenames_set):\n    X_list, Y_list = [], []\n    subset = df_labels[df_labels['filename'].isin(filenames_set)]\n    \n    for fname, group in tqdm(subset.groupby('filename'), desc=\"Обробка аудіо\"):\n        path = DATA_DIR / \"train_soundscapes\" / fname\n        try:\n            sig, _ = librosa.load(path, sr=SAMPLE_RATE, duration=60)\n            if len(sig) < AUDIO_LEN:\n                sig = np.pad(sig, (0, AUDIO_LEN - len(sig)))\n        except Exception:\n            continue\n            \n        for _, row in group.iterrows():\n            t_start = int(pd.to_timedelta(row['start']).total_seconds())\n            t_end = int(pd.to_timedelta(row['end']).total_seconds())\n            \n            if t_end - t_start != 5: continue\n                \n            audio_chunk = sig[t_start * SAMPLE_RATE : t_end * SAMPLE_RATE]\n            X_list.append(get_audio_features(audio_chunk))\n            \n            birds = [b.strip() for b in str(row['primary_label']).split(';')]\n            y_vec = np.zeros(NUM_BIRDS)\n            for b in birds:\n                if b in BIRD_SPECIES:\n                    y_vec[BIRD_SPECIES.index(b)] = 1\n            Y_list.append(y_vec)\n            \n    return np.array(X_list), np.array(Y_list)\n\nprint(\"Збірка Train...\")\nX_tr, Y_tr = build_xy(train_files)\nprint(\"Збірка Val...\")\nX_v, Y_v = build_xy(val_files)\n\n# Масштабування та PCA\nscaler = StandardScaler()\npca = PCA(n_components=128, random_state=42)\n\nX_tr_pca = pca.fit_transform(scaler.fit_transform(X_tr))\nX_v_pca = pca.transform(scaler.transform(X_v))","metadata":{"execution":{"iopub.status.busy":"2026-04-06T20:40:39.161740Z","iopub.execute_input":"2026-04